// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  subtitle    String?
  icon        String?
  description String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events      Event[]

  @@map("categories")
}

model Event {
  id          String   @id @default(cuid())
  name        String
  slug        String
  description String?
  date        DateTime?
  location    String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  images      Image[]

  @@unique([slug, categoryId])
  @@map("events")
}

model Image {
  id          String   @id @default(cuid())
  filename    String
  originalName String?
  url         String
  thumbnailUrl String?
  alt         String?
  width       Int?
  height      Int?
  size        Int?
  mimeType    String?  // Tipul fișierului (image/jpeg, video/mp4, etc.)
  duration    Int?     // Durata video-ului în secunde (doar pentru video)
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("images")
}

model ShowreelVideo {
  id          String   @id @default(cuid())
  title       String   @default("Showreel")
  subtitle    String?
  videoUrl    String   // YouTube/Vimeo URL
  thumbnailUrl String? // Custom thumbnail (uploaded)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("showreel_videos")
}

model HeroSlide {
  id          String   @id @default(cuid())
  filename    String
  originalName String?
  url         String
  alt         String?
  title       String?  // Text overlay opțional
  subtitle    String?  // Subtitlu opțional
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  size        Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("hero_slides")
}

model Package {
  id          String   @id @default(cuid())
  name        String
  icon        String   @default("fas fa-camera")
  price       Int
  currency    String   @default("Euro")
  tier        String   @default("Pachet Basic")
  badge       String?
  features    Json     @default("[]")
  extras      Json     @default("[]")
  notes       Json     @default("[]")
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("packages")
}
